// ============================================================
// AURIQ — Final Prisma Schema
// Database: PostgreSQL (Neon)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// USERS
// ============================================================

model User {
  id                    Int       @id @default(autoincrement())
  name                  String
  email                 String    @unique
  password              String?   // null for guest checkout
  phone                 String?
  is_active             Boolean   @default(true)
  is_email_verified     Boolean   @default(false)
  email_verify_token    String?
  password_reset_token  String?
  password_reset_expiry DateTime?
  newsletter_sub        Boolean   @default(false)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  addresses      Address[]
  cart           Cart?
  orders         Order[]
  reviews        Review[]
  wishlist       Wishlist?
  refresh_tokens RefreshToken[]
  return_requests ReturnRequest[]
  discount_uses  DiscountUse[]

  @@map("users")
}

// ============================================================
// ADMIN
// ============================================================

model Admin {
  id                Int      @id @default(autoincrement())
  first_name        String   @default("Auriq")
  last_name         String   @default("Admin")
  email             String   @unique
  password          String
  phone             String?
  profile_image_url String?  // Cloudinary URL
  last_login        DateTime?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  refresh_tokens AdminRefreshToken[]
  audit_logs     AuditLog[]

  @@map("admins")
}

// ============================================================
// REFRESH TOKENS
// ============================================================

model RefreshToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expires_at DateTime
  created_at DateTime @default(now())

  @@map("refresh_tokens")
}

model AdminRefreshToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  admin_id   Int
  admin      Admin    @relation(fields: [admin_id], references: [id], onDelete: Cascade)
  device_info String?
  browser    String?
  ip_address String?
  last_active DateTime @default(now())
  expires_at DateTime
  created_at DateTime @default(now())

  @@map("admin_refresh_tokens")
}

// ============================================================
// ADDRESSES
// ============================================================

model Address {
  id            Int         @id @default(autoincrement())
  user_id       Int
  user          User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  type          AddressType @default(SHIPPING)
  label         String      // e.g. "Home", "Office"
  full_name     String
  phone         String
  street        String
  city          String
  province      String
  postal_code   String?
  is_default    Boolean     @default(false)
  created_at    DateTime    @default(now())

  orders        Order[]

  @@map("addresses")
}

enum AddressType {
  SHIPPING
  BILLING
}

// ============================================================
// CATEGORIES
// ============================================================

model Category {
  id            Int       @id @default(autoincrement())
  name          String    @unique  // Men, Women, Unisex, Bundles, Gift Sets
  slug          String    @unique
  image_url     String?
  meta_title    String?
  meta_desc     String?
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  products      Product[]

  @@map("categories")
}

// ============================================================
// COLLECTIONS (50ml, 100ml, Best Sellers, New Arrivals etc.)
// ============================================================

model Collection {
  id          Int       @id @default(autoincrement())
  name        String    @unique  // e.g. "50ml", "Best Sellers", "New Arrivals"
  slug        String    @unique
  image_url   String?
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  products    ProductCollection[]

  @@map("collections")
}

model ProductCollection {
  product_id    Int
  collection_id Int
  product       Product    @relation(fields: [product_id], references: [id], onDelete: Cascade)
  collection    Collection @relation(fields: [collection_id], references: [id], onDelete: Cascade)

  @@id([product_id, collection_id])
  @@map("product_collections")
}

// ============================================================
// PRODUCTS
// ============================================================

model Product {
  id              Int      @id @default(autoincrement())
  name            String
  slug            String   @unique
  description     String?
  brand           String   @default("Auriq")
  fragrance_type  String?  // Floral, Woody, Citrus, Fresh
  gender          Gender   @default(UNISEX)
  is_active       Boolean  @default(true)
  is_featured     Boolean  @default(false)
  is_best_seller  Boolean  @default(false)
  is_new_arrival  Boolean  @default(false)
  meta_title      String?
  meta_desc       String?
  weight_grams    Int?     // for future dynamic shipping
  category_id     Int
  category        Category @relation(fields: [category_id], references: [id])
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  variants        ProductVariant[]
  images          ProductImage[]
  fragrance_notes FragranceNote[]
  reviews         Review[]
  wishlist_items  WishlistItem[]
  collections     ProductCollection[]

  @@index([category_id])
  @@index([is_active])
  @@index([is_featured])
  @@map("products")
}

enum Gender {
  MALE
  FEMALE
  UNISEX
}

// ============================================================
// PRODUCT VARIANTS (size + price + stock per size)
// ============================================================

model ProductVariant {
  id              Int      @id @default(autoincrement())
  product_id      Int
  product         Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  size_ml         Int      // 10, 50, 100
  price           Decimal  @db.Decimal(10, 2)
  discount_price  Decimal? @db.Decimal(10, 2)
  stock_quantity  Int      @default(0)
  low_stock_alert Int      @default(5)  // alert when stock <= this
  sku             String   @unique      // e.g. AURIQ-LACEDA-50ML
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  cart_items      CartItem[]
  order_items     OrderItem[]
  bundle_items    BundleItem[]

  @@unique([product_id, size_ml])
  @@index([product_id])
  @@map("product_variants")
}

// ============================================================
// PRODUCT IMAGES
// ============================================================

model ProductImage {
  id          Int      @id @default(autoincrement())
  product_id  Int
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  image_url   String   // Cloudinary URL
  is_primary  Boolean  @default(false)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())

  @@index([product_id])
  @@map("product_images")
}

// ============================================================
// FRAGRANCE NOTES
// ============================================================

model FragranceNote {
  id         Int          @id @default(autoincrement())
  product_id Int
  product    Product      @relation(fields: [product_id], references: [id], onDelete: Cascade)
  note_type  NoteType     // TOP, HEART, BASE
  note_name  String       // e.g. Bergamot, Vetiver, Amber

  @@map("fragrance_notes")
}

enum NoteType {
  TOP
  HEART
  BASE
}

// ============================================================
// BUNDLES
// ============================================================

model Bundle {
  id              Int      @id @default(autoincrement())
  name            String
  slug            String   @unique
  description     String?
  price           Decimal  @db.Decimal(10, 2)   // discounted bundle price
  original_price  Decimal  @db.Decimal(10, 2)   // sum of individual prices
  image_url       String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  items           BundleItem[]
  cart_items      CartItem[]
  order_items     OrderItem[]

  @@map("bundles")
}

model BundleItem {
  id         Int            @id @default(autoincrement())
  bundle_id  Int
  bundle     Bundle         @relation(fields: [bundle_id], references: [id], onDelete: Cascade)
  variant_id Int
  variant    ProductVariant @relation(fields: [variant_id], references: [id])
  quantity   Int            @default(1)

  @@map("bundle_items")
}

// ============================================================
// CART
// ============================================================

model Cart {
  id         Int        @id @default(autoincrement())
  user_id    Int?       @unique  // null = guest cart
  session_id String?    @unique  // for guest checkout
  user       User?      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  items      CartItem[]

  @@index([user_id])
  @@index([session_id])
  @@map("carts")
}

model CartItem {
  id         Int             @id @default(autoincrement())
  cart_id    Int
  cart       Cart            @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  variant_id Int?            // null if bundle
  variant    ProductVariant? @relation(fields: [variant_id], references: [id])
  bundle_id  Int?            // null if single product
  bundle     Bundle?         @relation(fields: [bundle_id], references: [id])
  quantity   Int             @default(1)
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt

  @@map("cart_items")
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id              Int           @id @default(autoincrement())
  user_id         Int?          // null = guest order
  user            User?         @relation(fields: [user_id], references: [id])
  guest_email     String?       // for guest checkout
  guest_name      String?
  guest_phone     String?
  session_id      String?       // for guest order verification
  address_id      Int?
  address         Address?      @relation(fields: [address_id], references: [id])
  // snapshot shipping address (in case address is deleted later)
  shipping_name     String
  shipping_phone    String
  shipping_street   String
  shipping_city     String
  shipping_province String
  shipping_postal   String?
  status            OrderStatus   @default(PENDING)
  payment_method    PaymentMethod @default(COD)
  payment_status    PaymentStatus @default(UNPAID)
  subtotal          Decimal       @db.Decimal(10, 2)
  shipping_fee      Decimal       @db.Decimal(10, 2) @default(0)
  discount_amount   Decimal       @db.Decimal(10, 2) @default(0)
  total             Decimal       @db.Decimal(10, 2)
  discount_code     String?
  notes             String?
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  items           OrderItem[]
  return_requests ReturnRequest[]

  @@index([user_id])
  @@index([session_id])
  @@index([status])
  @@index([created_at])
  @@map("orders")
}

model OrderItem {
  id          Int             @id @default(autoincrement())
  order_id    Int
  order       Order           @relation(fields: [order_id], references: [id], onDelete: Cascade)
  variant_id  Int?
  variant     ProductVariant? @relation(fields: [variant_id], references: [id])
  bundle_id   Int?
  bundle      Bundle?         @relation(fields: [bundle_id], references: [id])
  item_name   String          // snapshot of product name
  item_sku    String?         // snapshot of SKU
  size_ml     Int?            // snapshot of size
  quantity    Int
  unit_price  Decimal         @db.Decimal(10, 2)  // price at time of order
  total_price Decimal         @db.Decimal(10, 2)

  @@map("order_items")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  WAREHOUSE
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  CARD
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

// ============================================================
// RETURN / CANCELLATION REQUESTS
// ============================================================

model ReturnRequest {
  id         Int          @id @default(autoincrement())
  order_id   Int
  order      Order        @relation(fields: [order_id], references: [id])
  user_id    Int
  user       User         @relation(fields: [user_id], references: [id])
  reason     String
  status     ReturnStatus @default(PENDING)
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt

  @@map("return_requests")
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

// ============================================================
// REVIEWS
// ============================================================

model Review {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product_id Int
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  rating     Int      // 1-5
  comment    String?
  is_active  Boolean  @default(true)
  is_featured Boolean @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([user_id, product_id])
  @@map("reviews")
}

// ============================================================
// WISHLIST
// ============================================================

model Wishlist {
  id         Int            @id @default(autoincrement())
  user_id    Int            @unique
  user       User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at DateTime       @default(now())

  items      WishlistItem[]

  @@map("wishlists")
}

model WishlistItem {
  id          Int      @id @default(autoincrement())
  wishlist_id Int
  wishlist    Wishlist @relation(fields: [wishlist_id], references: [id], onDelete: Cascade)
  product_id  Int
  product     Product  @relation(fields: [product_id], references: [id])
  created_at  DateTime @default(now())

  @@unique([wishlist_id, product_id])
  @@map("wishlist_items")
}

// ============================================================
// DISCOUNT CODES
// ============================================================

model DiscountCode {
  id          Int          @id @default(autoincrement())
  code        String       @unique  // e.g. WELCOME10
  type        DiscountType // PERCENTAGE or FLAT
  value       Decimal      @db.Decimal(10, 2)  // e.g. 10 for 10%
  min_order   Decimal      @db.Decimal(10, 2) @default(0)
  max_uses    Int?         // null = unlimited
  used_count  Int          @default(0)
  is_active   Boolean      @default(true)
  expires_at  DateTime?
  created_at  DateTime     @default(now())

  uses        DiscountUse[]

  @@map("discount_codes")
}

model DiscountUse {
  id               Int          @id @default(autoincrement())
  discount_code_id Int
  discount_code    DiscountCode @relation(fields: [discount_code_id], references: [id])
  user_id          Int
  user             User         @relation(fields: [user_id], references: [id])
  used_at          DateTime     @default(now())

  @@unique([discount_code_id, user_id])  // one use per user per code
  @@map("discount_uses")
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

// ============================================================
// NEWSLETTER SUBSCRIBERS
// ============================================================

model NewsletterSubscriber {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  discount_sent   Boolean  @default(false)
  subscribed_at   DateTime @default(now())

  @@map("newsletter_subscribers")
}

// ============================================================
// SHIPPING CONFIG
// Free shipping above threshold
// ============================================================

model ShippingConfig {
  id                    Int     @id @default(autoincrement())
  flat_fee              Decimal @db.Decimal(10, 2)
  free_shipping_above   Decimal @db.Decimal(10, 2)
  karachi_fee           Decimal @db.Decimal(10, 2) @default(200)
  city_to_city_fee      Decimal @db.Decimal(10, 2) @default(500)
  updated_at            DateTime @updatedAt

  @@map("shipping_config")
}

// ============================================================
// ADS / BANNERS
// ============================================================

model Ad {
  id               Int        @id @default(autoincrement())
  title            String
  image_url        String     // Cloudinary URL
  mobile_image_url String?    // Optional mobile-specific image
  link_url         String?
  button_text      String?    // Call to action text
  position         AdPosition @default(HERO)
  is_active        Boolean    @default(true)
  sort_order       Int        @default(0) // For drag-and-drop ordering
  starts_at        DateTime?
  ends_at          DateTime?
  created_at       DateTime   @default(now())
  updated_at       DateTime   @updatedAt

  @@map("ads")
}

enum AdPosition {
  HERO
  ANNOUNCEMENT_BAR
}

// ============================================================
// GALLERY / LOOK BOOK
// ============================================================

model GalleryImage {
  id          Int      @id @default(autoincrement())
  image_url   String   // Cloudinary URL
  caption     String?
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  @@map("gallery_images")
}

// ============================================================
// CONTACT MESSAGES
// ============================================================

model ContactMessage {
  id         Int           @id @default(autoincrement())
  name       String
  email      String
  phone      String?
  subject    String?
  message    String
  is_read    Boolean       @default(false)
  status     MessageStatus @default(UNREAD)
  created_at DateTime      @default(now())

  @@map("contact_messages")
}

enum MessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

// ============================================================
// SITE CONTENT (Our Story)
// ============================================================

model Story {
  id                    Int      @id @default(1)
  subtitle              String   @default("The Heritage")
  title                 String   @default("Crafting The Essence Of Elegance")
  paragraph1            String
  paragraph2            String
  image1_url            String
  image2_url            String?
  mission_statement     String?  @db.Text
  vision_statement      String?  @db.Text
  sourcing_details      String?  @db.Text
  manufacturing_process String?  @db.Text
  company_values        String?  @db.Text
  founder_message       String?  @db.Text
  video_url             String?
  updated_at            DateTime @updatedAt

  @@map("stories")
}

// ============================================================
// CMS SYSTEM SETTINGS
// ============================================================

model SystemSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String   @db.Text
  group       String   @default("GENERAL") // e.g., 'SEO', 'CONTACT', 'FOOTER', 'HOMEPAGE'
  updated_at  DateTime @updatedAt

  @@map("system_settings")
}

// ============================================================
// TESTIMONIALS
// ============================================================

model Testimonial {
  id            Int      @id @default(autoincrement())
  customer_name String
  content       String   @db.Text
  rating        Int      @default(5)
  is_featured   Boolean  @default(false)
  is_approved   Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("testimonials")
}

// ============================================================
// AUDIT LOGS
// ============================================================

model AuditLog {
  id             Int      @id @default(autoincrement())
  admin_id       Int
  admin          Admin    @relation(fields: [admin_id], references: [id])
  action         String
  entity_type    String
  entity_id      Int?
  previous_value String?  @db.Text
  new_value      String?  @db.Text
  created_at     DateTime @default(now())

  @@map("audit_logs")
}

